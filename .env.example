# Christina Pfeiffer Supabase project (read-only website content + email templates)
NEXT_PUBLIC_CP_SUPABASE_URL=
NEXT_PUBLIC_CP_SUPABASE_ANON_KEY=

# Email is sent entirely by Supabase Edge Functions (send-booking-request,
# submit-subscriber, send-subscriber-broadcast). Set GMAIL_USER + GMAIL_APP_PASSWORD
# as Supabase Edge Function secrets — they are NOT needed in this website env.

# Canonical site origin used for SEO (canonical tags, hreflang, sitemap, robots,
# OG image URLs). Optional — defaults to https://christinapfeiffer.de. Only set
# this to point a preview/staging deploy at its own origin.
# NEXT_PUBLIC_SITE_URL=https://christinapfeiffer.de
